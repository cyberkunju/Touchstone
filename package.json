{
  "name": "edge-docgraph-engine",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src vite.config.ts vitest.config.ts --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "setup:models": "node scripts/fetch-models.mjs",
    "setup:ort": "node scripts/copy-ort-wasm.mjs",
    "setup": "node scripts/copy-ort-wasm.mjs && node scripts/fetch-models.mjs",
    "postinstall": "node scripts/copy-ort-wasm.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "comlink": "^4.4.1",
    "idb": "^8.0.1",
    "lucide-react": "^0.400.0",
    "onnxruntime-web": "^1.19.2",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zxing-wasm": "^1.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "bwip-js": "^4.11.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "exceljs": "^4.4.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "puppeteer": "^25.1.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "protobufjs": "^7.6.5",
    "uuid": "^11.1.1"
  }
}
