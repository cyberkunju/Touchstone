            },
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          ],
          "minItems": 4,
          "maxItems": 4
        },
        "PixelBox": {
          "type": "array",
          "description": "Pixel [x1, y1, x2, y2] coordinates.",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "minItems": 4,
          "maxItems": 4
        },
        "Point": {
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "Confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "FieldStatus": {
          "type": "string",
          "enum": [
            "confirmed",
            "needs_review",
            "missing",
            "conflict",
            "invalid",
            "unsupported",
            "rejected"
          ]
        },
        "ValueType": {
          "type": "string",
          "enum": [
            "text",
            "name",
            "date",
            "amount",
            "id_number",
            "address",
            "phone",
            "email",
            "country",
            "photo",
            "signature",
            "stamp",
