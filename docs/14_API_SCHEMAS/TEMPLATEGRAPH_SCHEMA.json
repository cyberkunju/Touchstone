{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-docgraph-engine.local/schemas/TEMPLATEGRAPH_SCHEMA.json",
  "title": "TemplateGraph",
  "description": "Machine-readable schema for correction-driven local template memory.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "familyId",
    "version",
    "name",
    "createdAt",
    "updatedAt",
    "pageCount",
    "canonicalPages",
    "anchors",
    "fields",
    "assets",
    "tables",
    "validators",
    "fingerprint",
    "status"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/Id"
    },
    "schemaVersion": {
      "type": "string",
      "const": "templategraph-v1"
    },
    "familyId": {
      "$ref": "#/$defs/Id"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "docType": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "deprecated",
        "archived"
      ]
    },
    "createdAt": {
      "$ref": "#/$defs/TimestampMs"
    },
    "updatedAt": {
      "$ref": "#/$defs/TimestampMs"
    },
    "pageCount": {
      "type": "integer",
      "minimum": 1
    },
    "canonicalPages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pageIndex",
          "widthNorm",
          "heightNorm"
        ],
        "properties": {
          "pageIndex": {
            "type": "integer",
            "minimum": 0
          },
          "widthNorm": {
            "type": "number",
            "const": 1000
          },
          "heightNorm": {
            "type": "number",
            "minimum": 1
          }
        }
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateAnchor"
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateField"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateAsset"
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateTable"
      }
    },
    "codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateCode"
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateValidator"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TemplateRelationship"
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "layoutHash"
      ],
      "properties": {
        "layoutHash": {
          "type": "string"
        },
        "visualHash": {
          "type": "string"
        },
        "textAnchorHash": {
          "type": "string"
        },
        "specialZoneHash": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity"
        },
        "containsSampleValues": {
          "type": "boolean"
        },
        "containsThumbnails": {
          "type": "boolean"
        },
        "exportWarningRequired": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_:\\-\\.]+$"
    },
    "TimestampMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix epoch timestamp in milliseconds."
    },
    "NormalizedBox": {
      "type": "array",
      "description": "Normalized [x1, y1, x2, y2] coordinates in page space.",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "PixelBox": {
      "type": "array",
      "description": "Pixel [x1, y1, x2, y2] coordinates.",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "Point": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "Confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "FieldStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "needs_review",
        "missing",
        "conflict",
        "invalid",
        "unsupported",
        "rejected"
      ]
    },
    "ValueType": {
      "type": "string",
      "enum": [
        "text",
        "name",
        "date",
        "amount",
        "id_number",
        "address",
        "phone",
        "email",
        "country",
        "photo",
        "signature",
        "stamp",
        "seal",
        "logo",
        "emblem",
        "flag",
        "symbol",
        "qr",
        "barcode",
        "mrz",
        "table",
        "checkbox",
        "unknown"
      ]
    },
    "EvidenceSource": {
      "type": "string",
      "enum": [
        "upload",
        "pdf_parser",
        "image_normalizer",
        "detector",
        "ocr",
        "segmenter",
        "barcode_parser",
        "mrz_parser",
        "table_engine",
        "template_engine",
        "verifier",
        "user_correction",
        "import",
        "system"
      ]
    },
    "Sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "highly_sensitive"
      ]
    },
    "GraphNodeType": {
      "type": "string",
      "enum": [
        "page",
        "text_word",
        "text_line",
        "text_block",
        "field",
        "visual_asset",
        "table",
        "table_cell",
        "checkbox",
        "barcode",
        "qr",
        "mrz",
        "signature",
        "stamp",
        "seal",
        "logo",
        "photo",
        "document_boundary",
        "template_anchor",
        "quality_region",
        "unknown_region"
      ]
    },
    "GraphEdgeType": {
      "type": "string",
      "enum": [
        "contains",
        "near",
        "label_of",
        "value_of",
        "same_row",
        "same_column",
        "inside_table",
        "validated_by",
        "conflicts_with",
        "derived_from",
        "template_projected_from",
        "corrected_by",
        "overlaps",
        "reading_order_next"
      ]
    },
    "TemplateAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "pageIndex",
        "boxNorm",
        "importance",
        "stability"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "visual_asset",
            "geometry",
            "keypoint",
            "special_zone",
            "table_grid"
          ]
        },
        "pageIndex": {
          "type": "integer",
          "minimum": 0
        },
        "boxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "text": {
          "type": "string"
        },
        "assetType": {
          "$ref": "#/$defs/ValueType"
        },
        "descriptorRef": {
          "$ref": "#/$defs/Id"
        },
        "importance": {
          "$ref": "#/$defs/Confidence"
        },
        "stability": {
          "$ref": "#/$defs/Confidence"
        },
        "mustNotContainVariableValue": {
          "type": "boolean"
        }
      }
    },
    "TemplateField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "pageIndex",
        "valueBoxNorm",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "label": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "type": {
          "$ref": "#/$defs/ValueType"
        },
        "pageIndex": {
          "type": "integer",
          "minimum": 0
        },
        "labelBoxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "valueBoxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "ocrMode": {
          "type": "string",
          "enum": [
            "roi",
            "roi_high_res",
            "full_page_context"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "validatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity"
        }
      }
    },
    "TemplateAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "assetType",
        "pageIndex",
        "boxNorm",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "assetType": {
          "$ref": "#/$defs/ValueType"
        },
        "pageIndex": {
          "type": "integer",
          "minimum": 0
        },
        "boxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "useSegmentationRefinement": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "validatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TemplateTable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pageIndex",
        "boxNorm",
        "columns",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "pageIndex": {
          "type": "integer",
          "minimum": 0
        },
        "boxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "type"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/Id"
              },
              "label": {
                "type": "string"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "type": {
                "$ref": "#/$defs/ValueType"
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        },
        "variableRows": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "validatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TemplateCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "codeType",
        "pageIndex",
        "boxNorm",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "codeType": {
          "type": "string",
          "enum": [
            "qr",
            "barcode",
            "pdf417",
            "data_matrix",
            "aztec",
            "unknown"
          ]
        },
        "pageIndex": {
          "type": "integer",
          "minimum": 0
        },
        "boxNorm": {
          "$ref": "#/$defs/NormalizedBox"
        },
        "required": {
          "type": "boolean"
        },
        "payloadParsers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TemplateValidator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "validatorId",
        "targetIds",
        "severity"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "validatorId": {
          "type": "string"
        },
        "targetIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Id"
          }
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "TemplateRelationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "from",
        "to"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "type": {
          "type": "string",
          "enum": [
            "cross_check",
            "table_total",
            "date_order",
            "payload_match",
            "required_dependency",
            "alias_of"
          ]
        },
        "from": {
          "$ref": "#/$defs/Id"
        },
        "to": {
          "$ref": "#/$defs/Id"
        },
        "validatorId": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}