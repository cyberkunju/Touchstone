{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-docgraph-engine.local/schemas/VALIDATION_SCHEMA.json",
  "title": "ValidationResult",
  "description": "Machine-readable schema for verifier/validator output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "documentId",
    "targetId",
    "validatorId",
    "status",
    "severity",
    "message",
    "evidenceIds",
    "createdAt"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/Id"
    },
    "schemaVersion": {
      "type": "string",
      "const": "validation-v1"
    },
    "documentId": {
      "$ref": "#/$defs/Id"
    },
    "targetId": {
      "$ref": "#/$defs/Id"
    },
    "targetType": {
      "type": "string",
      "enum": [
        "field",
        "asset",
        "table",
        "cell",
        "mrz",
        "barcode",
        "template",
        "document",
        "page",
        "node"
      ]
    },
    "validatorId": {
      "type": "string"
    },
    "validatorVersion": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail",
        "not_applicable"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "message": {
      "type": "string"
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "description": "Structured safe details. Must not contain raw sensitive values unless explicitly allowed by privacy policy."
    },
    "evidenceIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Id"
      }
    },
    "createdAt": {
      "$ref": "#/$defs/TimestampMs"
    },
    "statusImpact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "suggestedFieldStatus": {
          "$ref": "#/$defs/FieldStatus"
        },
        "blocksConfirmation": {
          "type": "boolean"
        },
        "createsConflict": {
          "type": "boolean"
        },
        "requiresUserReview": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_:\\-\\.]+$"
    },
    "TimestampMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix epoch timestamp in milliseconds."
    },
    "NormalizedBox": {
      "type": "array",
      "description": "Normalized [x1, y1, x2, y2] coordinates in page space.",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "PixelBox": {
      "type": "array",
      "description": "Pixel [x1, y1, x2, y2] coordinates.",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "Point": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "Confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "FieldStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "needs_review",
        "missing",
        "conflict",
        "invalid",
        "unsupported",
        "rejected"
      ]
    },
    "ValueType": {
      "type": "string",
      "enum": [
        "text",
        "name",
        "date",
        "amount",
        "id_number",
        "address",
        "phone",
        "email",
        "country",
        "photo",
        "signature",
        "stamp",
        "seal",
        "logo",
        "emblem",
        "flag",
        "symbol",
        "qr",
        "barcode",
        "mrz",
        "table",
        "checkbox",
        "unknown"
      ]
    },
    "EvidenceSource": {
      "type": "string",
      "enum": [
        "upload",
        "pdf_parser",
        "image_normalizer",
        "detector",
        "ocr",
        "segmenter",
        "barcode_parser",
        "mrz_parser",
        "table_engine",
        "template_engine",
        "verifier",
        "user_correction",
        "import",
        "system"
      ]
    },
    "Sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "highly_sensitive"
      ]
    },
    "GraphNodeType": {
      "type": "string",
      "enum": [
        "page",
        "text_word",
        "text_line",
        "text_block",
        "field",
        "visual_asset",
        "table",
        "table_cell",
        "checkbox",
        "barcode",
        "qr",
        "mrz",
        "signature",
        "stamp",
        "seal",
        "logo",
        "photo",
        "document_boundary",
        "template_anchor",
        "quality_region",
        "unknown_region"
      ]
    },
    "GraphEdgeType": {
      "type": "string",
      "enum": [
        "contains",
        "near",
        "label_of",
        "value_of",
        "same_row",
        "same_column",
        "inside_table",
        "validated_by",
        "conflicts_with",
        "derived_from",
        "template_projected_from",
        "corrected_by",
        "overlaps",
        "reading_order_next"
      ]
    }
  }
}