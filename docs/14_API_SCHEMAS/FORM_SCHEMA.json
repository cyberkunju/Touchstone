{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-docgraph-engine.local/schemas/FORM_SCHEMA.json",
  "title": "EditableForm",
  "description": "Machine-readable schema for the generated editable form view projected from DocGraph.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "documentId",
    "createdAt",
    "sections",
    "fields",
    "reviewSummary"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/Id"
    },
    "schemaVersion": {
      "type": "string",
      "const": "form-v1"
    },
    "documentId": {
      "$ref": "#/$defs/Id"
    },
    "templateId": {
      "$ref": "#/$defs/Id"
    },
    "createdAt": {
      "$ref": "#/$defs/TimestampMs"
    },
    "updatedAt": {
      "$ref": "#/$defs/TimestampMs"
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FormSection"
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FormField"
      }
    },
    "reviewSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed",
        "needsReview",
        "missing",
        "conflict",
        "invalid",
        "unsupported",
        "exportReady"
      ],
      "properties": {
        "confirmed": {
          "type": "integer",
          "minimum": 0
        },
        "needsReview": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "conflict": {
          "type": "integer",
          "minimum": 0
        },
        "invalid": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported": {
          "type": "integer",
          "minimum": 0
        },
        "exportReady": {
          "type": "boolean"
        },
        "criticalUnresolved": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_:\\-\\.]+$"
    },
    "TimestampMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix epoch timestamp in milliseconds."
    },
    "NormalizedBox": {
      "type": "array",
      "description": "Normalized [x1, y1, x2, y2] coordinates in page space.",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "PixelBox": {
      "type": "array",
      "description": "Pixel [x1, y1, x2, y2] coordinates.",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "Point": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "Confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "FieldStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "needs_review",
        "missing",
        "conflict",
        "invalid",
        "unsupported",
        "rejected"
      ]
    },
    "ValueType": {
      "type": "string",
      "enum": [
        "text",
        "name",
        "date",
        "amount",
        "id_number",
        "address",
        "phone",
        "email",
        "country",
        "photo",
        "signature",
        "stamp",
        "seal",
        "logo",
        "emblem",
        "flag",
        "symbol",
        "qr",
        "barcode",
        "mrz",
        "table",
        "checkbox",
        "unknown"
      ]
    },
    "EvidenceSource": {
      "type": "string",
      "enum": [
        "upload",
        "pdf_parser",
        "image_normalizer",
        "detector",
        "ocr",
        "segmenter",
        "barcode_parser",
        "mrz_parser",
        "table_engine",
        "template_engine",
        "verifier",
        "user_correction",
        "import",
        "system"
      ]
    },
    "Sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "highly_sensitive"
      ]
    },
    "GraphNodeType": {
      "type": "string",
      "enum": [
        "page",
        "text_word",
        "text_line",
        "text_block",
        "field",
        "visual_asset",
        "table",
        "table_cell",
        "checkbox",
        "barcode",
        "qr",
        "mrz",
        "signature",
        "stamp",
        "seal",
        "logo",
        "photo",
        "document_boundary",
        "template_anchor",
        "quality_region",
        "unknown_region"
      ]
    },
    "GraphEdgeType": {
      "type": "string",
      "enum": [
        "contains",
        "near",
        "label_of",
        "value_of",
        "same_row",
        "same_column",
        "inside_table",
        "validated_by",
        "conflicts_with",
        "derived_from",
        "template_projected_from",
        "corrected_by",
        "overlaps",
        "reading_order_next"
      ]
    },
    "FormSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "fieldIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "fieldIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Id"
          }
        }
      }
    },
    "FormField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hypothesisId",
        "label",
        "type",
        "status",
        "value",
        "source",
        "evidenceIds",
        "validationIds",
        "editable",
        "required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "hypothesisId": {
          "$ref": "#/$defs/Id"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ValueType"
        },
        "status": {
          "$ref": "#/$defs/FieldStatus"
        },
        "value": {},
        "displayValue": {
          "type": [
            "string",
            "null"
          ]
        },
        "normalizedValue": {},
        "required": {
          "type": "boolean"
        },
        "editable": {
          "type": "boolean"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pageId"
          ],
          "properties": {
            "pageId": {
              "$ref": "#/$defs/Id"
            },
            "boxNorm": {
              "$ref": "#/$defs/NormalizedBox"
            },
            "cropArtifactId": {
              "$ref": "#/$defs/Id"
            },
            "sourceKind": {
              "type": "string",
              "enum": [
                "ocr",
                "asset",
                "table",
                "mrz",
                "barcode",
                "template_roi",
                "manual",
                "missing"
              ]
            }
          }
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Id"
          }
        },
        "validationIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Id"
          }
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "control": {
              "type": "string",
              "enum": [
                "text",
                "textarea",
                "date",
                "amount",
                "asset_crop",
                "table",
                "checkbox",
                "code_payload",
                "mrz_panel",
                "unsupported"
              ]
            },
            "priority": {
              "type": "string",
              "enum": [
                "critical",
                "high",
                "normal",
                "low"
              ]
            },
            "showInReviewQueue": {
              "type": "boolean"
            }
          }
        },
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity"
        }
      }
    }
  }
}